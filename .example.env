# Service
SERVICE_NAME=example
SERVICE_ENVIRONMENT=local
SERVICE_VERSION=1.0.0

# API
API_ADDRESS=localhost:8080
API_CORS_ORIGINS=*
API_TIMEOUT=30s
API_SWAGGER_ENABLED=true

# JWT
JWT_ENABLED=false
JWT_PUBLIC_KEY=MCowBQYDK2VwAyEAwggfjC0JqoTCejZGFvSQoP50+3wdftcIBNkZU1w4JPg=
JWT_PRIVATE_KEY=MC4CAQAwBQYDK2VwBCIEIPHEJfftv7kbcWtE+PJvUMdpofbVEO2fsSCBQ2UygOHj
JWT_ISSUER=issuer
JWT_AUDIENCE=audience
JWT_CLAIMS_TTL=24h

# Logger
LOG_LEVEL=DEBUG

# Postgres database
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=admin
DB_NAME=test
DB_SCHEMA=public
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNECTIONS=10
DB_MAX_IDLE_CONNECTIONS=2

# Redis
REDIS_ADDRESSES=localhost:6379
REDIS_MASTER=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS_DISABLED=false

# RabbitMQ
RABBITMQ_ENABLED=true
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=localhost
RABBITMQ_LISTENER_PORT=5672
RABBITMQ_VHOST=

# Kafka
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092

# OpenTelemetry
OTEL_SDK_DISABLED=false
OTEL_SERVICE_NAME=example
OTEL_RESOURCE_ATTRIBUTES=service.version=1.0.0,deployment.environment=local
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_METRIC_EXPORT_INTERVAL=15000
OTEL_TRACES_SAMPLER=traceidratio
OTEL_TRACES_SAMPLER_ARG=1

# Random user API
RANDOM_USER_BASE_URL=https://randomuser.me
